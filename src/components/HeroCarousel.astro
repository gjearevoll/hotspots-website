---
import { readFileSync, existsSync } from "fs";
import { join } from "path";
import yaml from "js-yaml";

interface HeroImage {
  file: string;
  species: string;
  common_name: string;
  photographer: string;
  institution: string;
  license: string;
  source_url: string;
  alt_text: string;
}

const yamlPath = join(process.cwd(), "src/data/hero-images.yaml");
const raw = readFileSync(yamlPath, "utf-8");
const allImages = yaml.load(raw) as HeroImage[];

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Only include images that exist in public/images/species/
const images = allImages.filter((img) =>
  existsSync(join(process.cwd(), "public/images/species", img.file))
);
---

<div class="hero-carousel" id="heroCarousel" aria-label="Biletkarusell">
  {images.length === 0 ? (
    <!-- No images yet: plain gradient fallback -->
    <div class="hero-slide hero-slide--active hero-slide--placeholder"></div>
  ) : (
    images.map((img, i) => (
      <div
        class={`hero-slide${i === 0 ? " hero-slide--active" : ""}`}
        data-index={i}
        aria-hidden={i !== 0 ? "true" : "false"}
      >
        <img
          src={`${base}/images/species/${img.file}`}
          alt={img.alt_text}
          class="hero-slide__img"
          loading={i === 0 ? "eager" : "lazy"}
          decoding="async"
        />
        <div class="hero-slide__overlay"></div>
        <a
          class="hero-slide__attribution"
          href={img.source_url}
          target="_blank"
          rel="noopener noreferrer"
          tabindex="-1"
          aria-label={`Kjelde: ${img.species} – ${img.photographer}`}
        >
          <em>{img.species}</em> ({img.common_name}) · Foto: {img.photographer} · {img.license}
        </a>
      </div>
    ))
  )}

  {images.length > 1 && (
    <div class="hero-dots" role="tablist" aria-label="Biletval">
      {images.map((_, i) => (
        <button
          class={`hero-dot${i === 0 ? " hero-dot--active" : ""}`}
          data-target={i}
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          aria-label={`Bilete ${i + 1}`}
        ></button>
      ))}
    </div>
  )}
</div>

<style>
.hero-carousel {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.hero-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 1s ease;
  pointer-events: none;
}

.hero-slide--active {
  opacity: 1;
  pointer-events: auto;
}

.hero-slide--placeholder {
  background: linear-gradient(135deg, var(--green-dark) 0%, #2a5e3a 60%, var(--green) 100%);
  opacity: 1;
}

.hero-slide__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.hero-slide__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(15, 40, 20, 0.45) 0%,
    rgba(15, 40, 20, 0.25) 50%,
    rgba(15, 40, 20, 0.65) 100%
  );
}

.hero-slide__attribution {
  position: absolute;
  bottom: 3.5rem;
  right: 1rem;
  font-size: 0.72rem;
  color: rgba(255, 255, 255, 0.75);
  text-decoration: none;
  background: rgba(0, 0, 0, 0.25);
  padding: 0.2rem 0.5rem;
  border-radius: 3px;
  backdrop-filter: blur(2px);
  max-width: 480px;
  text-align: right;
  line-height: 1.4;
  transition: color 0.15s;
}

.hero-slide__attribution:hover {
  color: rgba(255, 255, 255, 1);
}

.hero-dots {
  position: absolute;
  bottom: 1rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 0.5rem;
  z-index: 10;
}

.hero-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: 1.5px solid rgba(255, 255, 255, 0.7);
  background: transparent;
  cursor: pointer;
  padding: 0;
  transition: background 0.2s, border-color 0.2s;
}

.hero-dot--active {
  background: white;
  border-color: white;
}

.hero-dot:hover {
  background: rgba(255, 255, 255, 0.6);
}

@media (max-width: 640px) {
  .hero-slide__attribution {
    bottom: 0;
    right: 0;
    left: 0;
    max-width: 100%;
    border-radius: 0;
    text-align: left;
    font-size: 0.65rem;
    padding: 0.2rem 0.6rem;
  }

  .hero-dots {
    bottom: 1.6rem;
  }
}
</style>

<script>
  const carousel = document.getElementById("heroCarousel");
  if (carousel) {
    const slides = carousel.querySelectorAll<HTMLElement>(".hero-slide:not(.hero-slide--placeholder)");
    const dots = carousel.querySelectorAll<HTMLButtonElement>(".hero-dot");
    const INTERVAL = 6000;
    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let paused = false;

    function goTo(index: number) {
      slides[current].classList.remove("hero-slide--active");
      slides[current].setAttribute("aria-hidden", "true");
      dots[current]?.classList.remove("hero-dot--active");
      dots[current]?.setAttribute("aria-selected", "false");

      current = (index + slides.length) % slides.length;

      slides[current].classList.add("hero-slide--active");
      slides[current].setAttribute("aria-hidden", "false");
      dots[current]?.classList.add("hero-dot--active");
      dots[current]?.setAttribute("aria-selected", "true");
    }

    function next() {
      goTo(current + 1);
    }

    function startTimer() {
      if (slides.length < 2) return;
      timer = setInterval(() => {
        if (!paused) next();
      }, INTERVAL);
    }

    function stopTimer() {
      if (timer) clearInterval(timer);
    }

    // Dot click
    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        goTo(Number(dot.dataset.target));
        stopTimer();
        startTimer();
      });
    });

    // Pause on hover
    carousel.addEventListener("mouseenter", () => { paused = true; });
    carousel.addEventListener("mouseleave", () => { paused = false; });

    // Keyboard accessibility
    carousel.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "ArrowRight") { goTo(current + 1); stopTimer(); startTimer(); }
      if (e.key === "ArrowLeft")  { goTo(current - 1); stopTimer(); startTimer(); }
    });

    startTimer();
  }
</script>
