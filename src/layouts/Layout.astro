---
import "../styles/global.css";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import { config } from "../lib/config.ts";

interface Props {
  title: string;
  description?: string;
  activePage: "om" | "folk" | "kodebase" | "kart" | "publikasjonar";
  lang: "no" | "en";
}

const {
  title,
  description = "National portal for comprehensive biodiversity maps in Norway",
  activePage,
  lang,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const langBase = `${base}/${lang}`;
const htmlLang = lang === "en" ? "en" : "nn";
const projectName = config.project.name[lang];
const institution = config.project.institution[lang];

const navLinks =
  lang === "no"
    ? [
        { href: `${langBase}/`,          label: "Om prosjektet", key: "om" },
        { href: `${langBase}/folk/`,     label: "Folk",          key: "folk" },
        { href: `${langBase}/kodebase/`, label: "Kodebase",      key: "kodebase" },
        { href: `${langBase}/kart/`,     label: "Kart",          key: "kart" },
      ]
    : [
        { href: `${langBase}/`,          label: "About",         key: "om" },
        { href: `${langBase}/folk/`,     label: "People",        key: "folk" },
        { href: `${langBase}/kodebase/`, label: "Codebase",      key: "kodebase" },
        { href: `${langBase}/kart/`,     label: "Maps",          key: "kart" },
      ];

const footerContact = lang === "no" ? "Kontakt" : "Contact";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · {projectName}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.33.0/dist/tabler-icons.min.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={`${langBase}/`} class="site-logo">
          <div class="logo-mark">
            <svg viewBox="0 0 24 24" fill="none" stroke="#2a6e3f" stroke-width="2.5" stroke-linecap="round">
              <circle cx="12" cy="12" r="9"/>
              <circle cx="12" cy="12" r="4"/>
              <line x1="12" y1="3" x2="12" y2="8"/>
              <line x1="12" y1="16" x2="12" y2="21"/>
              <line x1="3" y1="12" x2="8" y2="12"/>
              <line x1="16" y1="12" x2="21" y2="12"/>
            </svg>
          </div>
          <div class="logo-text">
            <span class="logo-name">{projectName}</span>
            <span class="logo-sub">{institution}</span>
          </div>
        </a>

        <div class="header-right">
          <nav>
            {navLinks.map(link => (
              <a href={link.href} class={activePage === link.key ? "active" : ""}>
                {link.label}
              </a>
            ))}
          </nav>
          <LanguageSwitcher lang={lang} page={activePage} />
        </div>
      </div>
    </header>

    <main class="content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-left">
          <strong>{institution}</strong>
        </div>
        <div class="footer-right">
          <a href={config.project.github_org} target="_blank" rel="noopener">GitHub</a>
          <a href={`mailto:${config.project.contact_email}`}>{footerContact}</a>
          <a href={config.project.institution_url} target="_blank" rel="noopener">{institution}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
