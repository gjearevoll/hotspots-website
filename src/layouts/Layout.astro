---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  activePage: "om" | "folk" | "kodebase" | "kart" | "publikasjonar";
}

const { title, description = "Nasjonal portal for heildekkande kart over biologisk mangfald i Noreg", activePage } = Astro.props;

const base = import.meta.env.BASE_URL;

const navLinks = [
  { href: `${base}/`, label: "Om prosjektet", key: "om" },
  { href: `${base}/folk/`, label: "Folk", key: "folk" },
  { href: `${base}/kodebase/`, label: "Kodebase", key: "kodebase" },
  { href: `${base}/kart/`, label: "Kart", key: "kart" },
];
---

<!doctype html>
<html lang="nn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Hotspots</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={`${base}/`} class="site-logo">
          <div class="logo-mark">
            <svg viewBox="0 0 24 24" fill="none" stroke="#2a6e3f" stroke-width="2.5" stroke-linecap="round">
              <circle cx="12" cy="12" r="9"/>
              <circle cx="12" cy="12" r="4"/>
              <line x1="12" y1="3" x2="12" y2="8"/>
              <line x1="12" y1="16" x2="12" y2="21"/>
              <line x1="3" y1="12" x2="8" y2="12"/>
              <line x1="16" y1="12" x2="21" y2="12"/>
            </svg>
          </div>
          <div class="logo-text">
            <span class="logo-name">Hotspots</span>
            <span class="logo-sub">Gjærevollsenteret · NTNU</span>
          </div>
        </a>
        <nav>
          {navLinks.map(link => (
            <a
              href={link.href}
              class={activePage === link.key ? "active" : ""}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-left">
          <strong>Gjærevollsenteret · NTNU</strong> — Framtidsanalysar av naturmangfald
        </div>
        <div class="footer-right">
          <a href="https://github.com/gjaerevollsenteret" target="_blank" rel="noopener">GitHub</a>
          <a href="mailto:anders.finstad@ntnu.no">Kontakt</a>
          <a href="https://www.ntnu.no/gjaerevollsenteret" target="_blank" rel="noopener">Gjærevollsenteret</a>
        </div>
      </div>
    </footer>
  </body>
</html>
