---
import Layout from "../../layouts/Layout.astro";
import HeroCarousel from "../../components/HeroCarousel.astro";
import PublicationList from "../../components/PublicationList.astro";
import FocusBox from "../../components/FocusBox.astro";
import { config } from "../../lib/config.ts";
import { fetchPublications, fetchProjectMeta } from "../../lib/nva.ts";

const { cristin_project_id } = config.nva;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const meta = await fetchProjectMeta(cristin_project_id);
const projectDescription = meta?.description?.["en"] ?? meta?.description?.["nb"] ?? "";
const funders = meta?.funders ?? [];

const recentPubs = await fetchPublications(cristin_project_id, { size: 3 });
---

<Layout title="About" activePage="om" lang="en">
  <section class="hero hero--carousel">
    <HeroCarousel />
    <div class="hero-inner">
      <p class="hero-eyebrow">NTNU Gjærevoll Centre · The Hotspots project</p>
      <h1>Comprehensive maps of<br/>biodiversity in Norway</h1>
      <p class="hero-tagline">
        We develop the knowledge base for area-based nature management using
        integrated species distribution models and open data.
      </p>
    </div>
  </section>

  <div class="section">
    <div class="two-col">
      <div class="prose">
        <h2>About the Hotspots project</h2>
        {projectDescription
          ? projectDescription.split("\n\n").map((para: string) => <p>{para}</p>)
          : <p>Description fetched from NVA at next build.</p>
        }
        <p style="margin-top:1rem;">
          <a href={`https://nva.sikt.no/projects/${cristin_project_id}`} target="_blank" rel="noopener"
             style="font-size:0.85rem; color:var(--green);">
            See the project in NVA →
          </a>
        </p>
      </div>

      <div>
        <FocusBox lang="en" />

        <div class="card card-white" style="margin-top: 1rem;">
          <h3>Funded by</h3>
          <div class="funder-list">
            {funders.map(f => (
              <div class="funder-item">
                <div class="funder-dot"></div>
                <span>{f.name}{f.ref ? <span class="funder-ref"> · {f.ref}</span> : ""}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section-alt">
    <div class="section">
      <h2 class="section-heading">Recent publications</h2>
      <PublicationList
        publications={recentPubs}
        emptyMessage="No publications found."
      />
      <p style="margin-top:1.5rem;">
        <a href={`${base}/en/publikasjonar/`} style="color:var(--green); font-weight:600; text-decoration:none;">
          See all publications →
        </a>
      </p>
    </div>
  </div>
</Layout>
